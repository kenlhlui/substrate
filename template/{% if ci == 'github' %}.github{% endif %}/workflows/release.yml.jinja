# Customized GitHub Actions workflow for bumping version and creating a release using commitizen.
# Modified from https://github.com/commitizen-tools/setup-cz/blob/main/examples/bump-release.yaml
# Initialize the repositroy with 'cz init' first. Then install the Prek and Pre-commit Integration. Lastly add the workflow.

on:
  push:
    branches:
      - main

name: Release

jobs:
  bump:
    runs-on: ubuntu-latest
    if: "startsWith(github.event.head_commit.message, 'bump:')"
    permissions:
      contents: write
      actions: write
    steps:
      - uses: actions/checkout@v7
        with:
          fetch-depth: 0
          fetch-tags: true
      - name: Set up uv
        uses: astral-sh/setup-uv@v8.3.2
      
      - name: Install Commitizen with uv tools
        run: |
          uv tool install commitizen
      
      - name: Get the new version
        id: get-version
        run: |
          echo "new_version=$(cz version -p)" >> $GITHUB_OUTPUT
          echo "new_version_tag=$(cz version -p --tag)" >> $GITHUB_OUTPUT
      - name: Build changelog for Release
        env:
          NEW_VERSION: {% raw %}${{{% endraw %} steps.get-version.outputs.new_version }}
        # The following command might not be the best way to get the latest changelog.
        run: |
          awk '/^## /{c++} c==1' CHANGELOG.md > .changelog.md
      - name: GitHub Release
        if: {% raw %}${{{% endraw %} steps.get-version.outputs.new_version != '' }}
        env:
          GH_TOKEN: {% raw %}${{{% endraw %} github.token }}
          NEW_VERSION_TAG: {% raw %}${{{% endraw %} steps.get-version.outputs.new_version_tag }}
        run: |
          gh release create "${NEW_VERSION_TAG}" --notes-file .changelog.md
{% if with_pypi_publish %}
  pypi_publish:
    runs-on: ubuntu-latest
    needs: bump
    permissions:
      id-token: write
      contents: read
    steps:
      - name: Checkout repository
        uses: actions/checkout@v7
      - name: Install uv
        uses: astral-sh/setup-uv@v8.2.0
        with:
          version: latest
      - name: Build
        run: uv build
      - name: Publish
        run: uv publish
{% endif %}